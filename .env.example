# Copy this file to .env and fill in the values you want to use locally.
# Keep this file committed; never commit your real .env file.

# Required for OpenAI-powered profile parsing, trust-path ranking,
# reasoning explanations, and outreach draft generation.
OPENAI_API_KEY=

# Required for Exa-powered public person/company discovery.
EXA_API_KEY=

# Local backend configuration. Production platforms usually inject PORT automatically.
API_PORT=8890

# Optional for split local dev. Leave empty in production so the frontend calls the same deployed origin.
VITE_API_BASE_URL=http://localhost:8890
